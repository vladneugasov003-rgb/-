# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ОБЯЗАТЕЛЬНО: ваш ключ от Anthropic (получите на console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# JWT секрет (придумайте любую длинную строку)
JWT_SECRET=замените-на-случайную-строку-минимум-32-символа

# Порт бэкенда (по умолчанию 3001)
PORT=3001

# URL фронтенда для CORS (по умолчанию Vite dev)
FRONTEND_URL=http://localhost:5173
